# =============================================================================
# Yebone Backend — Environment Variables
# Copy this file to `.env` (project root) or `config/.env` and fill in values.
# Do not commit real secrets.
# =============================================================================

# --- Server ---
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# --- Database (MongoDB Atlas) ---
DB_URL=

# --- Database (PostgreSQL — future platform layer) ---
POSTGRES_URL=postgresql://user:password@localhost:5432/guriraline

# --- JWT / Auth ---
JWT_SECRET_KEY=
JWT_EXPIRES=7d
ACTIVATION_SECRET=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- URLs ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# Production example:
# FRONTEND_URL=https://bonerablaise.github.io/yebo-marketplace
# CORS_ORIGINS=https://bonerablaise.github.io,https://www.bonerablaise.github.io
RATE_LIMIT_MAX=120

# --- Storage ---
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./storage/uploads
STORAGE_MAX_MB=100

# --- Cloudinary (legacy + cloud storage placeholder) ---
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email ---
EMAIL_PROVIDER=placeholder
EMAIL_FROM=noreply@example.com
RESEND_API_KEY=
SMPT_HOST=
SMPT_PORT=587
SMPT_SERVICE=
SMPT_MAIL=
SMPT_PASSWORD=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_API_KEY=

# --- YEBO AI (Phase 7.1+ — backend only, MockProvider active in 7.1) ---
AI_PRIMARY_PROVIDER=mock
AI_MAX_MESSAGE_LENGTH=4000
AI_CHAT_RATE_LIMIT_MAX=20
AI_SEARCH_RATE_LIMIT_MAX=30
# Future live providers (Phase 7.4+):
# AI_OPENROUTER_API_KEY=
# AI_GEMINI_API_KEY=
# AI_OPENAI_API_KEY=
# AI_ANTHROPIC_API_KEY=
# AI_GROQ_API_KEY=
